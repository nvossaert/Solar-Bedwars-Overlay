{
  "name": "solar-overlay",
  "version": "1.0.0",
  "description": "Custom Hypixel Bedwars overlay (Cubelify-style) with Urchin blacklist integration, screen-capture hiding, and a self-hosted sniper/threat score.",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "test": "node test/stats.test.js",
    "dist": "electron-builder --win"
  },
  "author": "Nath (nvossaert)",
  "license": "MIT",
  "devDependencies": {
    "electron": "^31.7.6",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "gg.solar.overlay",
    "productName": "Solar Overlay",
    "files": [
      "src/**/*",
      "data/**/*",
      "assets/**/*",
      "package.json",
      "!src/main/secrets.js"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon-256.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
